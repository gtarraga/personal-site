---
import Layout from '../layouts/Layout.astro';
import ShelfItem from '../components/ShelfItem.astro';
import { getShelfItems } from '../lib/shelf';

const shelfItems = getShelfItems();
---

<Layout title="media shelf - guillem tarraga">
	<div class="container">
		<h1>media shelf</h1>
		<div class="shelf-header">
			<p>Books and films I've recently enjoyed.</p>
			<div class="legend">
				<span class="legend-filter-icon" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24">
						<path fill="currentColor" d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z" />
					</svg>
				</span>
				<span class="legend-item legend-film" data-filter="film">Films</span>
				<span class="legend-item legend-book" data-filter="book">Books</span>
			</div>
		</div>

		<div class="shelf-grid" data-shelf-page>
			{shelfItems.map((item) => <ShelfItem item={item} />)}
		</div>
	</div>
	<script>
		import { hydrateShelf } from '../lib/shelf-client';

		hydrateShelf();
	</script>
</Layout>

<script>
	const filters = document.querySelectorAll('.legend-item');
	let activeFilter: string | null = null;

	const syncShelfFilter = () => {
		const items = document.querySelectorAll('.shelf-item');

		if (!activeFilter) {
			items.forEach(item => item.classList.remove('hidden'));
			return;
		}

		items.forEach(item => {
			if (item.getAttribute('data-type') === activeFilter) {
				item.classList.remove('hidden');
			} else {
				item.classList.add('hidden');
			}
		});
	};

	filters.forEach(filter => {
		filter.addEventListener('click', () => {
			const type = filter.getAttribute('data-filter');

			if (activeFilter === type) {
				activeFilter = null;
				filters.forEach(f => f.classList.remove('active'));
			} else {
				activeFilter = type;
				filters.forEach(f => f.classList.remove('active'));
				filter.classList.add('active');
			}

			syncShelfFilter();
		});
	});

	document.addEventListener('shelf:updated', syncShelfFilter);
</script>

<style is:global>
	.shelf-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 1.5rem;
	}

	.shelf-header p {
		margin: 0;
	}

	.legend {
		display: flex;
		align-items: center;
		gap: 12px;
		font-size: 0.75rem;
		color: #737373;
		margin-left: 8px;
		white-space: nowrap;
	}

	.legend-filter-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		line-height: 0;
		color: #737373;
		margin-right: -4px;
	}

	.legend-filter-icon svg {
		display: block;
		/* funnel glyph reads top-heavy in 24×24; nudge to align with label cap height */
		transform: translateY(0.08em);
	}

	.legend-item {
		cursor: pointer;
		transition: color 0.2s, text-decoration 0.2s;
	}

	.legend-item:hover {
		text-decoration: underline;
		color: var(--text-color);
	}

	.legend-item.active {
		font-weight: 600;
		color: var(--text-color);
		text-decoration: underline;
	}

	.legend-film::before {
		content: '';
		display: inline-block;
		width: 6px;
		height: 10px;
		background-color: #3498db;
		border-radius: 1px;
		margin-right: 4px;
		vertical-align: middle;
	}

	.legend-book::before {
		content: '';
		display: inline-block;
		width: 6px;
		height: 10px;
		background-color: #e67e22;
		border-radius: 1px;
		margin-right: 4px;
		vertical-align: middle;
	}

	.shelf-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.shelf-item {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s ease, opacity 0.3s ease;
	}

	.shelf-item.hidden {
		display: none;
	}

	.shelf-item:hover {
		transform: scale(1.03);
		background-color: transparent;
	}

	.shelf-item-cover {
		position: relative;
		flex-shrink: 0;
	}

	.shelf-item-cover::after {
		content: '';
		position: absolute;
		left: -8px;
		top: 0;
		bottom: 0;
		width: 4px;
	}

	.shelf-item.media-film .shelf-item-cover::after {
		background-color: #3498db;
	}

	.shelf-item.media-book .shelf-item-cover::after {
		background-color: #e67e22;
	}

	.shelf-item img {
		display: block;
		width: 100%;
		aspect-ratio: 2/3;
		object-fit: contain;
		object-position: left;
	}

	.shelf-item-info {
		padding: 0.5rem;
		margin-top: 0.3rem;
		background-color: var(--muted-bg);
	}

	.shelf-item-title {
		display: block;
		font-size: 0.75rem;
		font-weight: 500;
		line-height: 1.3;
		overflow: hidden;
		text-overflow: ellipsis;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
	}

	.shelf-item-author {
		display: block;
		font-size: 0.65rem;
		color: #737373;
		margin-top: 2px;
	}

	.shelf-item-year {
		display: block;
		font-size: 0.65rem;
		color: #737373;
	}

	@media (max-width: 480px) {
		.shelf-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>

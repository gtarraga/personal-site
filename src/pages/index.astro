---
import Layout from '../layouts/Layout.astro';
import { getRecentMedia } from '../lib/shelf';

const shelfItems = getRecentMedia(2, 2);
---

<Layout title="guillem tarraga">
	<div class="container">
		<h1>hi! i'm guillem.</h1>
		
		<p class="section-label">about</p>
		<p>Some people call me <mark>will</mark>. I solve problems with software.<br>A high-leverage generalist, jumping from one rabbit hole to another.</p>

		<p class="section-label">work</p>
		<p>I'm currently improving airplane mainteinance and repairs by applying AI to the problem at <a href="https://www.iairgroup.com/es/" target="_blank">IAG</a>.</p>

		<p class="section-label">contact</p>
		<p>You can reach me on <a href="https://www.linkedin.com/in/guillem-tarraga" target="_blank">LinkedIn</a>. Or <a href="mailto:hi@gtarraga.com?subject=Hi%20from%20your%20site">email</a> me directly. <a href="https://github.com/gtarraga" target="_blank">GitHub</a> too.</p>

		<hr>

		<p class="section-label">things i've worked on</p>
		<div class="projects">
			<div class="project">
				<div class="project-info">
					<span class="project-name">KV Store</span>
					<span class="project-tag">Fun weekend project</span>
				</div>
				<a href="https://github.com/gtarraga/kv-store" target="_blank" class="project-stars">repo↗</a>
			</div>
			<div class="project">
				<div class="project-info">
					<span class="project-name">Paella for Engineers</span>
					<span class="project-tag">Community event</span>
				</div>
				<span class="project-stars">30+ attendees</span>
			</div>
			<div class="project">
				<div class="project-info">
					<span class="project-name">Paper Reading Club</span>
					<span class="project-tag">Side project</span>
				</div>
				<span class="project-stars">6 sessions</span>
			</div>
			<div class="project">
				<div class="project-info">
					<span class="project-name">Homelab</span>
					<span class="project-tag">Over-engineered homelab IaC</span>
				</div>
				<a href="https://github.com/gtarraga/homelab" target="_blank" class="project-stars">repo↗</a>
			</div>
		</div>




		<div class="side-by-side">
			<div class="shelf-section">
				<p class="section-label">media shelf</p>
				<div class="media-grid" data-shelf-home data-film-count="2" data-book-count="2">
					{shelfItems.map((item) => (
						<a href={item.url} target="_blank" class={`media-item media-${item.type}`}>
							<img src={item.imageUrl} alt={item.title} />
						</a>
					))}
				</div>
				<div class="shelf-link"><a href="/shelf" >view full shelf →</a></div>
			</div>
			<div class="rabbit-holes-section">
				<p class="section-label">current rabbit holes</p>
				<ul class="rabbit-holes-list">
					<li>Distributed systems</li>
					<li>China (history/geopolitics)</li>
					<li>Devops</li>
					<li>Semicon industry</li>
					<li>Lamps</li>
					<li>Ice cream making</li>
				</ul>
			</div>
		</div>
	</div>
	<script>
		import { hydrateShelf } from '../lib/shelf-client';

		hydrateShelf();
	</script>
</Layout>

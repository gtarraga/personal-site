---
import PostHog from '../components/posthog.astro';
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<PostHog />
		<meta charset="UTF-8" />
		<meta name="description" content="Guillem Tarraga (gtarraga). I solve problems with software. A high-leverage generalist, jumping from one rabbit hole to another. Here are some things I've worked on:" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Guillem Tarraga (gtarraga). I solve problems with software. A high-leverage generalist, jumping from one rabbit hole to another. Here are some things I've worked on:" />
		<meta property="og:url" content="https://gtarraga.com" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico">
    		<link rel="icon" type="image/png" sizes="160x160" href="/favicon-160x160.png">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@900&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300;400&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
		<header>
			<h1 class="site-title"><a href="/">guillem tarraga</a></h1>
		</header>
		<slot />
	</body>
</html>

<style is:global>
	* { 
		box-sizing: border-box; 
	}
	
	:root { 
		--text-color: #000; 
		--bg-color: #FFF; 
		--highlight-color: #ffd00066; 
		--muted-bg: #F2F0E5; 
	}
	
	body { 
		font-family: 'Geist Mono', 'Roboto Mono', monospace; 
		font-size: 14px; 
		font-weight: 400; 
		color: var(--text-color); 
		background-color: var(--bg-color); 
		margin: 0; 
		padding: 0; 
		line-height: 1.5; 
		text-rendering: optimizeLegibility; 
		-webkit-font-smoothing: antialiased; 
		-moz-osx-font-smoothing: grayscale; 
	}
	
	.container { 
		max-width: 750px; 
		margin: 0 auto; 
		padding: 60px 32px 32px 32px; 
	}
	
	header { 
		position: absolute; 
		top: 16px; 
		left: 32px; 
	}
	
	.site-title { 
		font-family: 'Merriweather', serif; 
		font-size: 24px; 
		font-weight: 900; 
		color: var(--text-color); 
		line-height: 1.2; 
		margin: 0; 
	}
	
	.site-title a { 
		color: inherit; 
		text-decoration: none; 
	}
	
	h1 { 
		font-family: 'Merriweather', serif; 
		font-size: 24px; 
		font-weight: 900; 
		color: var(--text-color); 
		line-height: 1.2; 
		margin: 0.5em 0 0.5em 0; 
	}
	
	p { 
		margin: 0 0 0.5em 0; 
	}
	
	a { 
		color: var(--text-color); 
		text-decoration: underline; 
		padding: 0 2px; 
		margin: 0 -2px; 
	}
	
	a:hover { 
		background-color: var(--highlight-color); 
	}
	
	.section-label { 
		background-color: var(--muted-bg); 
		padding: 2px 6px; 
		display: inline-block; 
		margin: 0.75em 0 0.25em 0; 
		font-family: 'Geist Mono', 'Roboto Mono', monospace; 
		font-weight: 400; 
	}
	
	mark { 
		background-color: var(--highlight-color); 
		color: inherit; 
		padding: 0 2px; 
	}
	
	ul { 
		margin: 0 0 0.75em 0; 
		padding-left: 1.5em; 
	}
	
	li { 
		margin-bottom: 0.25em; 
	}
	
	hr { 
		border: none; 
		border-top: 2px solid var(--muted-bg); 
		margin: 1em 0; 
	}
	
	blockquote { 
		background: var(--muted-bg); 
		border-left: 0; 
		margin: 0.75em 0; 
		padding: 12px; 
		font-weight: 300; 
	}
	
	blockquote p { 
		margin: 0; 
	}
	
	blockquote cite { 
		display: block; 
		margin-top: 0.5em; 
		font-style: normal; 
	}
	
	blockquote cite a { 
		color: var(--text-color); 
	}
	
	@media (max-width: 480px) { 
		header { 
			position: relative; 
			top: auto; 
			left: auto; 
			padding: 16px 32px 0 32px; 
		} 
		
		.container { 
			padding: 16px 32px 32px 32px; 
		} 
		
		.site-title { 
			font-size: 18px; 
		} 
	}

	.projects {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.project {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.625rem 0;
		text-decoration: none;
		color: var(--text-color);
		border-bottom: 1px solid var(--muted-bg);
		transition: all .2s ease;
		cursor: default;
	}

	.project:last-child {
		border-bottom: none;
	}

	.project:hover {
		padding-left: 0.5rem;
	}
	
	/* Override global link hover for anchor projects */
	a.project:hover {
		background-color: transparent;
	}

	.project-info {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.project-name {
		font-weight: 500;
		font-size: 0.875rem;
		letter-spacing: -0.01em;
	}

	.project-tag {
		color: #737373;
		font-size: 0.75rem;
		font-style: italic;
	}

	.project-stars {
		color: #737373;
		font-size: 0.75rem;
		font-variant-numeric: tabular-nums;
		flex-shrink: 0;
	}

	.side-by-side {
		display: flex;
		gap: 2rem;
		margin-top: 1rem;
	}

	.shelf-section {
		flex: 1;
	}

	.rabbit-holes-section {
		flex: 1;
	}

	.media-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		margin-bottom: 0.75rem;
		margin-top: 0.75rem;
	}

	.media-item {
		aspect-ratio: 2/3;
		width: 80%;
		margin: 0 auto;
		border-radius: 4px;
		display: block;
		position: relative;
		transition: transform 0.2s ease;
		flex-shrink: 0;
	}

	.media-item:hover {
		transform: scale(1.03);
		background-color: transparent;
	}

	.media-item img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.media-item::after {
		content: '';
		position: absolute;
		left: -6px;
		top: 0;
		bottom: 0;
		width: 4px;
	}

	.media-film::after {
		background-color: #e67e22;
	}

	.media-book::after {
		background-color: #3498db;
	}

	.shelf-link {
		font-size: 0.75rem;
		color: #737373;
		display: block;
		text-align: center;
		margin-top: 0.75rem;
	}

	.rabbit-holes-list {
		font-size: 0.875rem;
		margin-top: 1rem;
	}

	.rabbit-holes-list li {
		margin-bottom: 1.25em;
		line-height: 1.6;
	}

	@media (max-width: 600px) {
		.side-by-side {
			flex-direction: column;
			gap: 1rem;
		}
	}
</style>
	